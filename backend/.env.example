# 应用配置
LUI_APP_NAME=LUI-for-All
LUI_DEBUG=true

# 数据库配置
LUI_DB_PATH=workspace/lui.db

# 安全策略默认动作 (allow / confirm / block)
LUI_SAFETY_DEFAULT_ACTION=confirm

# MCP 对话网关静态 Bearer Token (可选，用于外部连接鉴权)
LUI_MCP_API_TOKEN=your-random-token-here

# 注意：Matchbox 主密钥 LLM_KEY 不在此文件中配置。
# 首次启动后，系统会在 workspace/agent_matchbox/.env 生成并读取 LLM_KEY。
