{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🔥 全栈开发 (热重载)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend",
            "python": "${command:python.interpreterPath}",
            "jinja": true,
            "justMyCode": false,
            "preLaunchTask": "Start Frontend"
        }
    ]
}
