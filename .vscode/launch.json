{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🐍 Backend (talk-to-interface)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend",
            "python": "${command:python.interpreterPath}",
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "🌐 Frontend (Vite)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/frontend"
        },
        {
            "name": "🧪 Backend (proj_for_test)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "6687",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/proj_for_test",
            "python": "${command:python.interpreterPath}",
            "jinja": true,
            "justMyCode": false
        }
    ],
    "compounds": [
        {
            "name": "🔥 全栈开发 (并行模式)",
            "configurations": [
                "🐍 Backend (talk-to-interface)",
                "🌐 Frontend (Vite)"
            ]
        }
    ]
}