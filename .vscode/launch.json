{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🐍 Backend",
            "type": "debugpy",
            "request": "launch",
            "program": "run.py",

            "cwd": "${workspaceFolder}/backend",
            "python": "${command:python.interpreterPath}",
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "🌐 Frontend",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/frontend"
        },
        {
            "name": "🧪 TestBackend FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8010",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/backend_for_test/fastapi_sample",
            "python": "${command:python.interpreterPath}",
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "🧪 TestBackend Node",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/backend_for_test/node_sample"
        }
    ],
    "compounds": [
        {
            "name": "🔥 全栈开发",
            "configurations": [
                "🐍 Backend",
                "🌐 Frontend"
            ]
        },
        {
            "name": "🌟 全栈测试",
            "configurations": [
                "🧪 TestBackend FastAPI",
                "🧪 TestBackend Node",
                "🌐 Frontend",
                "🐍 Backend"
            ]
        }
    ]
}