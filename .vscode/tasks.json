{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Backend (Hot Reload)",
            "type": "shell",
            "command": "${command:python.interpreterPath}",
            "args": [
                "-m",
                "uvicorn",
                "app.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Started server process",
                    "endsPattern": "Uvicorn running on"
                }
            },
            "presentation": {
                "group": "Talk-To-Interface",
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Start Frontend",
            "type": "npm",
            "script": "dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": ".",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "vite v",
                    "endsPattern": "Local:"
                }
            },
            "presentation": {
                "group": "Talk-To-Interface",
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
